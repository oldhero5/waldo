# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=waldo
POSTGRES_PASSWORD=waldo
POSTGRES_DB=waldo

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=waldo
MINIO_SECURE=false

# Hugging Face
HF_TOKEN=

# SAM 3 / 3.1 model selection
# - SAM3_MODEL_ID drives the PyTorch labeler (NVIDIA / CPU). It must point
#   at an HF repo that ships a transformers-compatible model.safetensors.
#   facebook/sam3 satisfies this; facebook/sam3.1 does NOT (it ships only
#   sam3.1_multiplex.pt), so the PyTorch path defaults to sam3 today.
# - SAM3_MLX_MODEL_ID drives the Apple Silicon labeler via MLX, which uses
#   the mlx-community repackage of SAM 3.1 weights.
SAM3_MODEL_ID=facebook/sam3
SAM3_MLX_MODEL_ID=mlx-community/sam3.1-bf16

# Device
DEVICE=mps
DTYPE=float32

# Notifications (all optional)
SLACK_WEBHOOK_URL=
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL=
